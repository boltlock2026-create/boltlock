{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/netao",
      "dest": "/frontend/netao/index.html"
    },
    {
      "src": "/netao/",
      "dest": "/frontend/netao/index.html"
    },
    {
      "src": "/netao/(.*)",
      "dest": "/frontend/netao/$1"
    },
    {
      "src": "/escolas",
      "dest": "/frontend/escolas/index.html"
    },
    {
      "src": "/escolas/",
      "dest": "/frontend/escolas/index.html"
    },
    {
      "src": "/escolas/(.*)",
      "dest": "/frontend/escolas/$1"
    },
    {
      "src": "/boltlock",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/boltlock/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/boltlock/(.*)",
      "dest": "/frontend/boltlock/$1"
    },
    {
      "src": "/apresentação",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentação/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresenta%C3%A7%C3%A3o",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresenta%C3%A7%C3%A3o/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentacao",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentacao/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/creditscore",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/creditscore/(.*)",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
