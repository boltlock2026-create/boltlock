{
  "version": 2,
  "buildCommand": "mkdir -p .vercel/output/static && cp -r frontend/* .vercel/output/static/",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/creditscore",
      "destination": "/index.html"
    },
    {
      "source": "/creditscore/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/netao",
      "destination": "/netao/index.html"
    },
    {
      "source": "/netao/(.*)",
      "destination": "/netao/$1"
    }
  ]
}
