{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/netao",
      "dest": "/frontend/netao/index.html"
    },
    {
      "src": "/netao/",
      "dest": "/frontend/netao/index.html"
    },
    {
      "src": "/netao/(.*)",
      "dest": "/frontend/netao/$1"
    },
    {
      "src": "/historiadaia",
      "dest": "/frontend/historiadaia/index.html"
    },
    {
      "src": "/historiadaia/",
      "dest": "/frontend/historiadaia/index.html"
    },
    {
      "src": "/historiadaia/(.*)",
      "dest": "/frontend/historiadaia/$1"
    },
    {
      "src": "/escolas/colegiovilareal",
      "dest": "/frontend/colegiovilareal/index.html"
    },
    {
      "src": "/escolas/colegiovilareal/",
      "dest": "/frontend/colegiovilareal/index.html"
    },
    {
      "src": "/escolas/colegiovilareal/(.*)",
      "dest": "/frontend/colegiovilareal/$1"
    },
    {
      "src": "/escolas/ospequeninos",
      "dest": "/frontend/ospequeninos/index.html"
    },
    {
      "src": "/escolas/ospequeninos/",
      "dest": "/frontend/ospequeninos/index.html"
    },
    {
      "src": "/escolas/ospequeninos/(.*)",
      "dest": "/frontend/ospequeninos/$1"
    },
    {
      "src": "/escolas/crm",
      "dest": "/frontend/crm/index.html"
    },
    {
      "src": "/escolas/crm/",
      "dest": "/frontend/crm/index.html"
    },
    {
      "src": "/escolas/crm/(.*)",
      "dest": "/frontend/crm/$1"
    },
    {
      "src": "/escolas/portal",
      "dest": "/frontend/portal/index.html"
    },
    {
      "src": "/escolas/portal/",
      "dest": "/frontend/portal/index.html"
    },
    {
      "src": "/escolas/portal/(.*)",
      "dest": "/frontend/portal/$1"
    },
    {
      "src": "/escolas/ferias",
      "dest": "/frontend/ferias/index.html"
    },
    {
      "src": "/escolas/ferias/",
      "dest": "/frontend/ferias/index.html"
    },
    {
      "src": "/escolas/ferias/(.*)",
      "dest": "/frontend/ferias/$1"
    },
    {
      "src": "/escolas",
      "dest": "/frontend/escolas/index.html"
    },
    {
      "src": "/escolas/",
      "dest": "/frontend/escolas/index.html"
    },
    {
      "src": "/escolas/(.*)",
      "dest": "/frontend/escolas/$1"
    },
    {
      "src": "/boltlock",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/boltlock/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/boltlock/(.*)",
      "dest": "/frontend/boltlock/$1"
    },
    {
      "src": "/apresentação",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentação/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresenta%C3%A7%C3%A3o",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresenta%C3%A7%C3%A3o/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentacao",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/apresentacao/",
      "dest": "/frontend/boltlock/index.html"
    },
    {
      "src": "/produtos",
      "dest": "/frontend/produtos/index.html"
    },
    {
      "src": "/produtos/",
      "dest": "/frontend/produtos/index.html"
    },
    {
      "src": "/produtos/assets/(.*)",
      "dest": "/frontend/produtos/assets/$1"
    },
    {
      "src": "/produtos/logos/(.*)",
      "dest": "/frontend/produtos/logos/$1"
    },
    {
      "src": "/produtos/([^/]+)/?",
      "dest": "/frontend/produtos/$1/index.html"
    },
    {
      "src": "/creditscore",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/creditscore/(.*)",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
