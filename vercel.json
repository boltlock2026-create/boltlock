{
  "version": 2,
  "buildCommand": "cp -r frontend .vercel/output/static 2>/dev/null || true",
  "env": {
    "FIREBASE_DATABASE_URL": "@firebase_database_url",
    "FIREBASE_SERVICE_ACCOUNT": "@firebase_service_account",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/creditscore",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/creditscore/(.*)",
      "destination": "/frontend/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
